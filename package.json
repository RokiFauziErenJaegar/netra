    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.1",
    "mysql2": "^3.11.4",
    "node-routeros": "^1.6.8",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {}
