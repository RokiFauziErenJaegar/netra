<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head', { title }) %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body>
<div class="app">
  <%- include('partials/sidebar', { page }) %>
  <div class="main">
    <%- include('partials/navbar', { title, navIcon: 'fa-solid fa-chart-line' }) %>
    <div class="content">

      <a href="/" class="btn btn--ghost btn--sm" style="margin-bottom: var(--space-4);">
        <i class="fa-solid fa-arrow-left"></i> Kembali ke Dashboard
      </a>

      <div class="card">
        <div class="card__head">
          <div>
            <h3 style="margin: 0;"><%= opd.nama_opd %></h3>
            <div class="muted fs-sm" style="margin-top: 4px;">
              <code><%= opd.ip_address %></code> ·
              Interface <code><%= opd.interface_name || '-' %></code> ·
              MAC <code><%= opd.mac_address || '-' %></code>
            </div>
          </div>
          <% if (opd.status_terakhir === 'Up') { %>
            <span class="badge badge--success"><i class="fa-solid fa-check"></i> Up</span>
          <% } else { %>
            <span class="badge badge--danger"><i class="fa-solid fa-xmark"></i> Down</span>
          <% } %>
        </div>
        <div class="card__body">
          <div class="chart-box"><canvas id="trafficChart"></canvas></div>
          <div id="emptyState" class="table__empty" style="display:none;">
            <i class="fa-solid fa-hourglass-half"></i> Belum ada data traffic untuk hari ini.
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
<script>window.__OPD_ID__ = <%= opd.id_opd %>;</script>
<script src="<%= asset('js/detail.js') %>" defer></script>
</body>
</html>
