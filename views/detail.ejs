<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head', { title }) %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
<div class="d-flex">
  <%- include('partials/sidebar', { page }) %>
  <div class="flex-grow-1">
    <%- include('partials/navbar', { title, navIcon: 'fa-solid fa-chart-line' }) %>
    <div class="container-fluid px-4">
      <a href="/" class="btn btn-sm btn-outline-secondary mb-3"><i class="fa-solid fa-arrow-left me-1"></i> Kembali</a>
      <div class="card shadow-sm mb-4">
        <div class="card-body">
          <h4 class="mb-1"><%= opd.nama_opd %></h4>
          <div class="text-muted small mb-3">
            IP: <code><%= opd.ip_address %></code> &nbsp;|&nbsp;
            Interface: <code><%= opd.interface_name || '-' %></code> &nbsp;|&nbsp;
            MAC: <code><%= opd.mac_address || '-' %></code> &nbsp;|&nbsp;
            Status terakhir: <strong><%= opd.status_terakhir %></strong>
          </div>
          <div style="height: 360px;">
            <canvas id="trafficChart"></canvas>
          </div>
          <div id="emptyState" class="text-center text-muted py-4 d-none">Belum ada data traffic untuk hari ini.</div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>window.__OPD_ID__ = <%= opd.id_opd %>;</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/static/js/detail.js"></script>
</body>
</html>
