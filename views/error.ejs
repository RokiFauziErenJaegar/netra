<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head', { title: 'Error ' + code }) %>
</head>
<body>
<div class="error-page">
  <div>
    <div class="error-code"><%= code %></div>
    <h2><%= message %></h2>
    <p class="text-muted">Maaf, terjadi masalah saat memproses permintaan Anda.</p>
    <a href="/" class="btn btn--primary" style="margin-top: var(--space-4);">
      <i class="fa-solid fa-home"></i> Kembali ke Dashboard
    </a>
  </div>
</div>
</body>
</html>
