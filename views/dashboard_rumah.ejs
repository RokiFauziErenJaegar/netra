<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head', { title }) %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body>
<div class="app">
  <%- include('partials/sidebar', { page }) %>
  <div class="main">
    <%- include('partials/navbar', { title, navIcon: 'fa-solid fa-house-signal' }) %>
    <div class="content">

      <div id="pesanDashboard" class="alert alert--info">
        <i class="fa-solid fa-circle-info"></i>
        <div>Menunggu update pertama…</div>
      </div>

      <div class="stats-grid">
        <div class="stat-card" data-tone="primary">
          <div class="stat-card__icon"><i class="fa-solid fa-ethernet"></i></div>
          <div class="stat-card__label">Total Interface</div>
          <div class="stat-card__value" id="totalInterface"><%= snapshot && snapshot.summary ? snapshot.summary.total : 0 %></div>
          <div class="stat-card__hint"><i class="fa-solid fa-server"></i> Router <%= routerHost %></div>
        </div>
        <div class="stat-card" data-tone="success">
          <div class="stat-card__icon"><i class="fa-solid fa-circle-check"></i></div>
          <div class="stat-card__label">Terhubung</div>
          <div class="stat-card__value" id="totalTerhubung"><%= snapshot && snapshot.summary ? snapshot.summary.terhubung : 0 %></div>
          <div class="stat-card__hint"><span class="dot dot--live"></span> Aktif</div>
        </div>
        <div class="stat-card" data-tone="danger">
          <div class="stat-card__icon"><i class="fa-solid fa-circle-xmark"></i></div>
          <div class="stat-card__label">Tidak Terhubung</div>
          <div class="stat-card__value" id="totalTidakTerhubung"><%= snapshot && snapshot.summary ? snapshot.summary.tidak_terhubung : 0 %></div>
          <div class="stat-card__hint"><span class="dot dot--down"></span> Down/Disabled</div>
        </div>
        <div class="stat-card" data-tone="info">
          <div class="stat-card__icon"><i class="fa-solid fa-address-card"></i></div>
          <div class="stat-card__label">DHCP Leases</div>
          <div class="stat-card__value" id="totalDhcp"><%= snapshot && snapshot.dhcpSummary ? snapshot.dhcpSummary.total : 0 %></div>
          <div class="stat-card__hint">
            <span id="totalDhcpAktif" class="text-success"><%= snapshot && snapshot.dhcpSummary ? snapshot.dhcpSummary.aktif : 0 %></span> aktif ·
            <span id="totalDhcpTidakAktif"><%= snapshot && snapshot.dhcpSummary ? snapshot.dhcpSummary.tidak_aktif : 0 %></span> idle
          </div>
        </div>
      </div>

      <!-- DHCP Section -->
      <section class="section">
        <div class="section__head">
          <div>
            <h2 class="section__title"><i class="fa-solid fa-address-card"></i> DHCP Leases Rumah</h2>
            <div class="section__subtitle">Daftar perangkat yang mendapat IP dari DHCP Server</div>
          </div>
        </div>
        <div class="table-wrap">
          <div class="table-scroll">
            <table class="table">
              <thead>
                <tr>
                  <th style="width:48px;">#</th>
                  <th>Perangkat</th>
                  <th>IP Address</th>
                  <th class="text-right">Bandwidth Aktif</th>
                  <th>Lease Info</th>
                  <th class="text-center">Status</th>
                </tr>
              </thead>
              <tbody id="dhcpRows">
                <% if (snapshot && snapshot.leases && snapshot.leases.length) { %>
                  <% snapshot.leases.forEach((row, i) => { %>
                    <tr>
                      <td class="muted"><%= i + 1 %></td>
                      <td>
                        <div class="strong"><%= row.host_name || 'Tanpa nama' %></div>
                        <div class="muted">ID: <%= row.routeros_id %></div>
                      </td>
                      <td><code><%= row.ip_address || '-' %></code></td>
                      <td class="text-right num strong text-accent text-nowrap"><%= fmtBytes(row.total_usage_bytes) %></td>
                      <td class="muted fs-xs">
                        <div>Last seen: <%= row.last_seen || '-' %></div>
                        <div>Expires: <%= row.expires_after || '-' %></div>
                      </td>
                      <td class="text-center">
                        <% if (String(row.lease_status).toLowerCase() === 'bound') { %>
                          <span class="badge badge--success"><i class="fa-solid fa-wifi"></i> Aktif</span>
                        <% } else { %>
                          <span class="badge badge--neutral"><%= String(row.lease_status || '').toUpperCase() %></span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="6" class="table__empty">Belum ada DHCP lease.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- Interface Section -->
      <section class="section">
        <div class="section__head">
          <div>
            <h2 class="section__title"><i class="fa-solid fa-server"></i> Status Interface MikroTik Rumah</h2>
            <div class="section__subtitle">Router <%= routerHost %> · Interval poll <%= cfg.poll.rumahMs %>ms</div>
          </div>
        </div>
        <div class="table-wrap">
          <div class="table-scroll">
            <table class="table">
              <thead>
                <tr>
                  <th style="width:48px;">#</th>
                  <th>Interface</th>
                  <th>Tipe</th>
                  <th>MAC Address</th>
                  <th class="text-right">Download</th>
                  <th class="text-right">Upload</th>
                  <th class="text-center">Disabled</th>
                  <th class="text-center">Status</th>
                  <th>Cek Terakhir</th>
                </tr>
              </thead>
              <tbody id="interfaceRows">
                <% if (snapshot && snapshot.interfaces && snapshot.interfaces.length) { %>
                  <% snapshot.interfaces.forEach((row, i) => { %>
                    <tr>
                      <td class="muted"><%= i + 1 %></td>
                      <td>
                        <div class="strong"><%= row.interface_name %></div>
                        <div class="muted">ID: <%= row.routeros_id %></div>
                      </td>
                      <td class="muted"><%= row.type || '-' %></td>
                      <td><code><%= row.mac_address || '-' %></code></td>
                      <td class="text-right num strong text-accent text-nowrap"><%= fmtMbps(row.last_rx_bps) %></td>
                      <td class="text-right num strong text-accent text-nowrap"><%= fmtMbps(row.last_tx_bps) %></td>
                      <td class="text-center">
                        <% if (Number(row.disabled) === 1) { %>
                          <span class="badge badge--warning"><i class="fa-solid fa-ban"></i> Ya</span>
                        <% } else { %>
                          <span class="badge badge--neutral">Tidak</span>
                        <% } %>
                      </td>
                      <td class="text-center">
                        <% if (row.status_terakhir === 'Terhubung') { %>
                          <span class="badge badge--success"><i class="fa-solid fa-check"></i> Terhubung</span>
                        <% } else { %>
                          <span class="badge badge--danger"><i class="fa-solid fa-xmark"></i> Tidak Terhubung</span>
                        <% } %>
                      </td>
                      <td class="muted fs-xs text-nowrap"><%= row.last_update %></td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="9" class="table__empty">Belum ada data interface.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- Traffic Analytics -->
      <section class="section">
        <div class="section__head">
          <div>
            <h2 class="section__title"><i class="fa-solid fa-chart-line"></i> Penggunaan Internet Interface</h2>
            <div class="section__subtitle">Periode: <span id="labelPeriode"><%= trafik.label %></span></div>
          </div>
          <div class="section__actions">
            <select id="filterPeriode" class="select">
              <option value="harian"   <%= periode === 'harian'   ? 'selected' : '' %>>Harian</option>
              <option value="mingguan" <%= periode === 'mingguan' ? 'selected' : '' %>>Mingguan</option>
              <option value="bulanan"  <%= periode === 'bulanan'  ? 'selected' : '' %>>Bulanan</option>
            </select>
            <a id="btnExportPdf" href="/rumah/laporan?periode=<%= periode %>" target="_blank" class="btn btn--danger btn--sm">
              <i class="fa-solid fa-file-pdf"></i> Export PDF
            </a>
          </div>
        </div>

        <div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
          <div class="card"><div class="card__body">
            <div class="stat-card__label">Estimasi Total</div>
            <div class="stat-card__value" id="trTotal" style="font-size: 1.4rem;"><%= trafik.ringkasan.total_pemakaian %></div>
          </div></div>
          <div class="card"><div class="card__body">
            <div class="stat-card__label">Rata-rata Download</div>
            <div class="stat-card__value" id="trAvgRx" style="font-size: 1.4rem;"><%= trafik.ringkasan.avg_rx %></div>
          </div></div>
          <div class="card"><div class="card__body">
            <div class="stat-card__label">Rata-rata Upload</div>
            <div class="stat-card__value" id="trAvgTx" style="font-size: 1.4rem;"><%= trafik.ringkasan.avg_tx %></div>
          </div></div>
          <div class="card"><div class="card__body">
            <div class="stat-card__label">Puncak Trafik</div>
            <div class="stat-card__value" id="trPeak" style="font-size: 1.4rem;"><%= trafik.ringkasan.peak %></div>
          </div></div>
        </div>

        <div class="card" style="margin-top: var(--space-4);">
          <div class="card__body">
            <div class="chart-box"><canvas id="trafficChart"></canvas></div>
          </div>
        </div>

        <div class="table-wrap" style="margin-top: var(--space-4);">
          <div class="table-scroll">
            <table class="table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Interface</th>
                  <th class="text-right">Rata-rata Download</th>
                  <th class="text-right">Rata-rata Upload</th>
                  <th class="text-right">Puncak Trafik</th>
                  <th class="text-right">Estimasi Pemakaian</th>
                  <th class="text-right">Sample</th>
                </tr>
              </thead>
              <tbody id="trafficRows">
                <% if (trafik.rows.length) { %>
                  <% trafik.rows.forEach((row, i) => { %>
                    <tr>
                      <td class="muted"><%= i + 1 %></td>
                      <td class="strong"><%= row.interface_name %></td>
                      <td class="text-right num"><%= fmtMbps(row.avg_rx) %></td>
                      <td class="text-right num"><%= fmtMbps(row.avg_tx) %></td>
                      <td class="text-right num"><%= fmtMbps(Math.max(Number(row.max_rx || 0), Number(row.max_tx || 0))) %></td>
                      <td class="text-right num strong"><%= fmtBytes(row.estimasi_bytes) %></td>
                      <td class="text-right muted fs-xs"><%= row.total_sample %> sampel</td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="7" class="table__empty">Belum ada data penggunaan untuk periode ini.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

    </div>
  </div>
</div>
<script>
  window.__INITIAL_TRAFFIC__ = <%- JSON.stringify(trafik.rows) %>;
  window.__INITIAL_PERIODE__ = <%- JSON.stringify(periode) %>;
</script>
<script src="<%= asset('js/dashboard_rumah.js') %>"></script>
</body>
</html>
