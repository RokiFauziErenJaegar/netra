<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head', { title }) %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body>
<div class="app">
  <%- include('partials/sidebar', { page }) %>
  <div class="main">
    <%- include('partials/navbar', { title, navIcon: 'fa-solid fa-users-gear' }) %>
    <div class="content">

      <div class="grid-2">
        <div class="card">
          <div class="card__head">
            <div>
              <h3 style="margin:0;"><i class="fa-solid fa-chart-column text-accent"></i> User Aktif per OPD</h3>
              <div class="muted fs-sm" style="margin-top: 4px;">Hotspot vs PPP / VPN</div>
            </div>
          </div>
          <div class="card__body">
            <div class="chart-box"><canvas id="opdChart"></canvas></div>
          </div>
        </div>

        <div class="card">
          <div class="card__head">
            <div>
              <h3 style="margin:0;"><i class="fa-solid fa-network-wired text-accent"></i> Status Koneksi Router</h3>
              <div class="muted fs-sm" style="margin-top: 4px;"><%= routers.length %> router OPD</div>
            </div>
          </div>
          <div class="table-scroll">
            <table class="table">
              <thead>
                <tr><th>OPD</th><th>Host</th><th>Status</th><th></th></tr>
              </thead>
              <tbody id="routerStatusRows">
                <% routers.forEach(r => { %>
                  <tr data-name="<%= r.name %>">
                    <td class="strong"><%= r.name %></td>
                    <td><code><%= r.host %></code></td>
                    <td><span class="badge badge--neutral status-cell">…</span></td>
                    <td>
                      <a href="/opd/<%= encodeURIComponent(r.name) %>" class="btn btn--ghost btn--sm detail-btn is-disabled">
                        <i class="fa-solid fa-eye"></i> Detail
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>
<script src="/static/js/opd_list.js"></script>
</body>
</html>
