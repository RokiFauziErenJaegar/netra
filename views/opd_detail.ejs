<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head', { title }) %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
<div class="d-flex">
  <%- include('partials/sidebar', { page }) %>
  <div class="flex-grow-1">
    <%- include('partials/navbar', { title, navIcon: 'fa-solid fa-users' }) %>
    <div class="container-fluid px-4">
      <a href="/opd" class="btn btn-sm btn-outline-secondary mb-3"><i class="fa-solid fa-arrow-left me-1"></i> Kembali</a>
      <h4 class="mb-1"><%= opd.name %></h4>
      <div class="text-muted small mb-3">Host: <code><%= opd.host %></code></div>

      <div id="errBox" class="alert alert-danger d-none"></div>

      <div class="row mb-4">
        <div class="col-md-6">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h6 class="card-title text-muted text-uppercase">Distribusi Tipe User</h6>
              <div style="height: 280px;"><canvas id="dist"></canvas></div>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h6 class="card-title text-muted text-uppercase">Top 5 Konsumsi Data (Hotspot)</h6>
              <div style="height: 280px;"><canvas id="top5"></canvas></div>
            </div>
          </div>
        </div>
      </div>

      <div class="table-wrapper mb-4">
        <h5 class="mb-3"><i class="fa-solid fa-wifi me-2"></i>Hotspot Aktif</h5>
        <div class="table-responsive">
          <table class="table table-hover align-middle" id="hotspotTable">
            <thead class="table-light"><tr><th>#</th><th>User</th><th>IP</th><th>MAC</th><th>Uptime</th><th>Download</th><th>Upload</th><th>Total</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>

      <div class="table-wrapper">
        <h5 class="mb-3"><i class="fa-solid fa-network-wired me-2"></i>PPP / VPN Aktif</h5>
        <div class="table-responsive">
          <table class="table table-hover align-middle" id="pppTable">
            <thead class="table-light"><tr><th>#</th><th>Service</th><th>User</th><th>Caller</th><th>Uptime</th></tr></thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
<script>window.__OPD_NAME__ = <%- JSON.stringify(opd.name) %>;</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/static/js/opd_detail.js"></script>
</body>
</html>
