<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head', { title }) %>
</head>
<body>
<div class="app">
  <%- include('partials/sidebar', { page }) %>
  <div class="main">
    <%- include('partials/navbar', { title, navIcon: 'fa-solid fa-gauge-high' }) %>
    <div class="content">

      <div id="pesanDashboard" class="alert alert--info">
        <i class="fa-solid fa-circle-info"></i>
        <div>Menunggu update pertama dari monitor service…</div>
      </div>

      <div class="stats-grid">
        <div class="stat-card" data-tone="primary">
          <div class="stat-card__icon"><i class="fa-solid fa-ethernet"></i></div>
          <div class="stat-card__label">Total Interface</div>
          <div class="stat-card__value" id="totalInterface"><%= snapshot && snapshot.summary ? snapshot.summary.total : 0 %></div>
          <div class="stat-card__hint"><i class="fa-solid fa-server"></i> Router <%= routerHost %></div>
        </div>
        <div class="stat-card" data-tone="success">
          <div class="stat-card__icon"><i class="fa-solid fa-circle-check"></i></div>
          <div class="stat-card__label">Terhubung</div>
          <div class="stat-card__value" id="totalUp"><%= snapshot && snapshot.summary ? snapshot.summary.up : 0 %></div>
          <div class="stat-card__hint"><span class="dot dot--live"></span> Status Up</div>
        </div>
        <div class="stat-card" data-tone="danger">
          <div class="stat-card__icon"><i class="fa-solid fa-circle-xmark"></i></div>
          <div class="stat-card__label">Tidak Terhubung</div>
          <div class="stat-card__value" id="totalDown"><%= snapshot && snapshot.summary ? snapshot.summary.down : 0 %></div>
          <div class="stat-card__hint"><span class="dot dot--down"></span> Status Down</div>
        </div>
        <div class="stat-card" data-tone="info">
          <div class="stat-card__icon"><i class="fa-solid fa-bolt"></i></div>
          <div class="stat-card__label">Interval Polling</div>
          <div class="stat-card__value"><%= (cfg.poll.diskominfoMs/1000).toFixed(1) %>s</div>
          <div class="stat-card__hint"><i class="fa-solid fa-arrows-rotate"></i> Real-time</div>
        </div>
      </div>

      <section class="section">
        <div class="section__head">
          <div>
            <h2 class="section__title">
              <i class="fa-solid fa-server"></i>
              Status Interface MikroTik Diskominfo
            </h2>
            <div class="section__subtitle">Update otomatis via WebSocket · Router <%= routerHost %></div>
          </div>
        </div>

        <div class="table-wrap">
          <div class="table-scroll">
            <table class="table">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Interface</th>
                  <th>Tipe</th>
                  <th>MAC Address</th>
                  <th class="text-right">Download</th>
                  <th class="text-right">Upload</th>
                  <th>Status</th>
                  <th>Cek Terakhir</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="interfaceRows">
                <% if (snapshot && snapshot.interfaces && snapshot.interfaces.length) { %>
                  <% snapshot.interfaces.forEach((row, i) => { %>
                    <tr>
                      <td class="muted"><%= i + 1 %></td>
                      <td>
                        <div class="strong"><%= row.interface_name %></div>
                        <div class="muted">ID: <%= row.routeros_id %></div>
                      </td>
                      <td class="muted"><%= row.type || '-' %></td>
                      <td><code><%= row.mac_address || '-' %></code></td>
                      <td class="text-right num text-accent strong"><%= fmtMbps(row.last_rx_bps) %></td>
                      <td class="text-right num text-accent strong"><%= fmtMbps(row.last_tx_bps) %></td>
                      <td>
                        <% if (row.status_terakhir === 'Up') { %>
                          <span class="badge badge--success"><i class="fa-solid fa-check"></i> Terhubung</span>
                        <% } else { %>
                          <span class="badge badge--danger"><i class="fa-solid fa-xmark"></i> Tidak Terhubung</span>
                        <% } %>
                      </td>
                      <td class="muted text-nowrap fs-xs"><%= row.last_update || '-' %></td>
                      <td>
                        <a href="/detail/<%= row.id_opd %>" class="btn btn--ghost btn--sm" title="Lihat detail traffic">
                          <i class="fa-solid fa-chart-line"></i>
                        </a>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="9" class="table__empty">
                    <i class="fa-solid fa-hourglass-half"></i> Menunggu poll pertama dari monitor service…
                  </td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </section>

    </div>
  </div>
</div>
<script src="/static/js/dashboard.js"></script>
</body>
</html>
