<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head', { title }) %>
</head>
<body>
<div class="d-flex">
  <%- include('partials/sidebar', { page }) %>
  <div class="flex-grow-1">
    <%- include('partials/navbar', { title, navIcon: 'fa-solid fa-gauge-high' }) %>

    <div class="container-fluid px-4">
      <div id="pesanDashboard" class="alert alert-info shadow-sm" role="alert">
        Menunggu update pertama dari monitor service…
      </div>

      <div class="row mb-4">
        <div class="col-md-4">
          <div class="card card-stats bg-primary text-white h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
              <div>
                <h6 class="card-title text-uppercase mb-0">Total Interface</h6>
                <h2 id="totalInterface" class="mt-2 mb-0"><%= snapshot && snapshot.summary ? snapshot.summary.total : 0 %></h2>
              </div>
              <i class="fa-solid fa-ethernet icon-lg"></i>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card card-stats bg-success text-white h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
              <div>
                <h6 class="card-title text-uppercase mb-0">Terhubung</h6>
                <h2 id="totalUp" class="mt-2 mb-0"><%= snapshot && snapshot.summary ? snapshot.summary.up : 0 %></h2>
              </div>
              <i class="fa-solid fa-circle-check icon-lg"></i>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card card-stats bg-danger text-white h-100">
            <div class="card-body d-flex justify-content-between align-items-center">
              <div>
                <h6 class="card-title text-uppercase mb-0">Tidak Terhubung</h6>
                <h2 id="totalDown" class="mt-2 mb-0"><%= snapshot && snapshot.summary ? snapshot.summary.down : 0 %></h2>
              </div>
              <i class="fa-solid fa-circle-xmark icon-lg"></i>
            </div>
          </div>
        </div>
      </div>

      <div class="table-wrapper mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <h5 class="mb-0"><i class="fa-solid fa-server me-2"></i>Status Interface MikroTik Diskominfo</h5>
            <small class="text-muted">Router: <%= routerHost %> | Interval poll: <%= cfg.poll.diskominfoMs %>ms</small>
          </div>
          <div>
            <span class="badge bg-light text-dark border" id="liveBadge"><i class="fa-solid fa-circle-notch fa-spin me-1"></i> Live</span>
          </div>
        </div>

        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead class="table-light">
              <tr>
                <th>#</th>
                <th>Interface</th>
                <th>Tipe</th>
                <th>MAC Address</th>
                <th>Download</th>
                <th>Upload</th>
                <th>Running</th>
                <th>Disabled</th>
                <th>Cek Terakhir</th>
                <th>Status</th>
                <th>Aksi</th>
              </tr>
            </thead>
            <tbody id="interfaceRows">
              <% if (snapshot && snapshot.interfaces && snapshot.interfaces.length) { %>
                <% snapshot.interfaces.forEach((row, i) => { %>
                  <tr>
                    <td><%= i + 1 %></td>
                    <td class="fw-bold"><%= row.interface_name %><br><small class="text-muted fw-normal">ID: <%= row.routeros_id %></small></td>
                    <td><%= row.type || '-' %></td>
                    <td><code><%= row.mac_address || '-' %></code></td>
                    <td class="fw-bold text-primary"><%= fmtMbps(row.last_rx_bps) %></td>
                    <td class="fw-bold text-info"><%= fmtMbps(row.last_tx_bps) %></td>
                    <td><%= Number(row.running) === 1 ? '<span class="text-success fw-bold">Ya</span>' : '<span class="text-danger fw-bold">Tidak</span>' %></td>
                    <td><%= Number(row.disabled) === 1 ? '<span class="text-danger fw-bold">Ya</span>' : '<span class="text-success fw-bold">Tidak</span>' %></td>
                    <td class="text-muted small"><%= row.last_update || '-' %></td>
                    <td>
                      <% if (row.status_terakhir === 'Up') { %>
                        <span class="badge bg-success rounded-pill px-3 py-2"><i class="fa-solid fa-check me-1"></i> TERHUBUNG</span>
                      <% } else { %>
                        <span class="badge bg-danger rounded-pill px-3 py-2"><i class="fa-solid fa-xmark me-1"></i> TIDAK TERHUBUNG</span>
                      <% } %>
                    </td>
                    <td><a href="/detail/<%= row.id_opd %>" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-chart-line"></i></a></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="11" class="text-center text-muted py-4">Belum ada data interface — menunggu poll pertama…</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="/static/js/dashboard.js"></script>
</body>
</html>
