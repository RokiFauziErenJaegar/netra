<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head', { title }) %>
  <style>
    @media print {
      .sidebar, .navbar, .no-print { display: none !important; }
      .main { margin-left: 0 !important; }
      body { background: #fff !important; color: #000 !important; }
      .card, .table { box-shadow: none !important; border: 1px solid #ccc !important; }
    }
    .filter-bar {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-3);
      align-items: end;
      padding: var(--space-4);
    }
    .filter-bar label { display: flex; flex-direction: column; gap: 4px; font-size: 0.85rem; }
    .filter-bar input[type="date"] {
      padding: 8px 10px;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--bg);
      color: var(--text);
      font-family: inherit;
    }
    .kategori-mati    { background: var(--danger-bg);  color: var(--danger);  }
    .kategori-hidup   { background: var(--success-bg); color: var(--success); }
    .kategori-disable { background: var(--warning-bg); color: var(--warning); }
  </style>
</head>
<body>
<div class="app">
  <%- include('partials/sidebar', { page }) %>
  <div class="main">
    <%- include('partials/navbar', { title, navIcon: 'fa-solid fa-file-lines' }) %>
    <div class="content">

      <!-- Filter form -->
      <div class="card no-print" style="margin-bottom: var(--space-5);">
        <div class="card__head">
          <div>
            <h3 style="margin:0;"><i class="fa-solid fa-filter text-accent"></i> Filter Periode Laporan</h3>
            <div class="muted fs-sm" style="margin-top: 4px;">Pilih rentang tanggal log event interface up/down/disable.</div>
          </div>
        </div>
        <form method="GET" action="/laporan-interface" class="filter-bar">
          <label>
            <span class="muted">Tanggal Mulai</span>
            <input type="date" name="start" value="<%= start %>" required>
          </label>
          <label>
            <span class="muted">Tanggal Akhir</span>
            <input type="date" name="end" value="<%= end %>" required>
          </label>
          <button type="submit" class="btn btn--primary">
            <i class="fa-solid fa-magnifying-glass"></i> Generate Laporan
          </button>
          <a href="/laporan-interface/export.csv?start=<%= start %>&end=<%= end %>"
             class="btn btn--ghost">
            <i class="fa-solid fa-file-csv"></i> Export CSV
          </a>
          <button type="button" class="btn btn--ghost" onclick="window.print()">
            <i class="fa-solid fa-print"></i> Print / Save PDF
          </button>
        </form>
      </div>

      <!-- Report header (untuk print) -->
      <div class="card" style="margin-bottom: var(--space-5);">
        <div class="card__body">
          <h2 style="margin: 0 0 8px;">Laporan Event Interface Diskominfo</h2>
          <div class="muted fs-sm">
            Periode: <strong><%= start %></strong> s.d. <strong><%= end %></strong>
            &middot; Router: <code><%= routerHost %></code>
            &middot; Dibuat: <%= new Date().toLocaleString('id-ID') %>
          </div>
        </div>
      </div>

      <!-- Ringkasan -->
      <div class="stats-grid" style="margin-bottom: var(--space-5);">
        <div class="stat-card" data-tone="primary">
          <div class="stat-card__icon"><i class="fa-solid fa-list"></i></div>
          <div class="stat-card__label">Total Event</div>
          <div class="stat-card__value"><%= summary.total %></div>
        </div>
        <div class="stat-card" data-tone="danger">
          <div class="stat-card__icon"><i class="fa-solid fa-circle-xmark"></i></div>
          <div class="stat-card__label">Mati (Down)</div>
          <div class="stat-card__value"><%= summary.mati %></div>
        </div>
        <div class="stat-card" data-tone="success">
          <div class="stat-card__icon"><i class="fa-solid fa-circle-check"></i></div>
          <div class="stat-card__label">Hidup (Pulih)</div>
          <div class="stat-card__value"><%= summary.hidup %></div>
        </div>
        <div class="stat-card" data-tone="warning">
          <div class="stat-card__icon"><i class="fa-solid fa-ban"></i></div>
          <div class="stat-card__label">Di-disable Admin</div>
          <div class="stat-card__value"><%= summary.disable %></div>
        </div>
      </div>

      <!-- Tabel detail -->
      <div class="card">
        <div class="card__head">
          <div>
            <h3 style="margin:0;"><i class="fa-solid fa-table text-accent"></i> Detail Event</h3>
            <div class="muted fs-sm" style="margin-top: 4px;">Urut dari yang paling lama ke terbaru.</div>
          </div>
        </div>
        <div class="table-scroll">
          <table class="table">
            <thead>
              <tr>
                <th style="width:48px;">#</th>
                <th>Waktu</th>
                <th>Interface</th>
                <th>Tipe</th>
                <th>MAC Address</th>
                <th class="text-center">Kategori</th>
                <th>Status (raw)</th>
              </tr>
            </thead>
            <tbody>
              <% if (!events.length) { %>
                <tr>
                  <td colspan="7" class="table__empty">
                    <i class="fa-solid fa-circle-info"></i>
                    Tidak ada event interface pada periode ini.
                  </td>
                </tr>
              <% } else { %>
                <% events.forEach((ev, i) => { %>
                  <tr>
                    <td class="muted"><%= i + 1 %></td>
                    <td class="text-nowrap fs-sm"><%= ev.waktu %></td>
                    <td class="strong"><%= ev.interface_name || '-' %></td>
                    <td class="muted"><%= ev.tipe || '-' %></td>
                    <td><code><%= ev.mac || '-' %></code></td>
                    <td class="text-center">
                      <% if (ev.kategori === 'MATI') { %>
                        <span class="badge kategori-mati"><i class="fa-solid fa-xmark"></i> MATI</span>
                      <% } else if (ev.kategori === 'HIDUP') { %>
                        <span class="badge kategori-hidup"><i class="fa-solid fa-check"></i> HIDUP</span>
                      <% } else { %>
                        <span class="badge kategori-disable"><i class="fa-solid fa-ban"></i> DISABLE</span>
                      <% } %>
                    </td>
                    <td class="muted fs-xs"><%= ev.status || '-' %></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <p class="muted fs-xs text-center" style="margin-top: var(--space-6);">
        Dokumen ini dihasilkan otomatis oleh sistem Netra &middot;
        Dinas Komunikasi dan Informatika Kabupaten Pringsewu
      </p>

    </div>
  </div>
</div>
</body>
</html>
