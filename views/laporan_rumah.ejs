<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head', { title }) %>
</head>
<body>
<div class="report">
  <div class="report__head">
    <div>
      <h1 class="report__title">Laporan Penggunaan Internet Rumah Ku</h1>
      <div class="report__meta">
        Periode: <strong><%= trafik.label %></strong> · Dibuat: <%= new Date().toLocaleString('id-ID') %><br>
        Router MikroTik: <code><%= routerHost %></code>
      </div>
    </div>
    <button class="btn btn--danger no-print" onclick="window.print()"><i class="fa-solid fa-file-pdf"></i> Export PDF</button>
  </div>

  <div class="stats-grid" style="grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));">
    <div class="card"><div class="card__body">
      <div class="stat-card__label">Estimasi Total</div>
      <div class="stat-card__value" style="font-size:1.5rem;"><%= trafik.ringkasan.total_pemakaian %></div>
    </div></div>
    <div class="card"><div class="card__body">
      <div class="stat-card__label">Rata-rata Download</div>
      <div class="stat-card__value" style="font-size:1.5rem;"><%= trafik.ringkasan.avg_rx %></div>
    </div></div>
    <div class="card"><div class="card__body">
      <div class="stat-card__label">Rata-rata Upload</div>
      <div class="stat-card__value" style="font-size:1.5rem;"><%= trafik.ringkasan.avg_tx %></div>
    </div></div>
    <div class="card"><div class="card__body">
      <div class="stat-card__label">Puncak Trafik</div>
      <div class="stat-card__value" style="font-size:1.5rem;"><%= trafik.ringkasan.peak %></div>
    </div></div>
  </div>

  <div class="table-wrap" style="margin-top: var(--space-6);">
    <table class="table">
      <thead>
        <tr>
          <th>#</th><th>Interface</th>
          <th class="text-right">Rata-rata Download</th>
          <th class="text-right">Rata-rata Upload</th>
          <th class="text-right">Puncak Trafik</th>
          <th class="text-right">Estimasi Pemakaian</th>
          <th class="text-right">Sample</th>
        </tr>
      </thead>
      <tbody>
        <% if (!trafik.rows.length) { %>
          <tr><td colspan="7" class="table__empty">Data penggunaan internet belum tersedia.</td></tr>
        <% } %>
        <% trafik.rows.forEach((row, i) => { %>
          <tr>
            <td class="muted"><%= i + 1 %></td>
            <td class="strong"><%= row.interface_name %></td>
            <td class="text-right num"><%= fmtMbps(row.avg_rx) %></td>
            <td class="text-right num"><%= fmtMbps(row.avg_tx) %></td>
            <td class="text-right num"><%= fmtMbps(Math.max(Number(row.max_rx || 0), Number(row.max_tx || 0))) %></td>
            <td class="text-right num strong"><%= fmtBytes(row.estimasi_bytes) %></td>
            <td class="text-right muted fs-xs"><%= row.total_sample %> sampel</td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <p class="muted fs-xs text-center" style="margin-top: var(--space-8);">
    Dokumen ini dihasilkan otomatis oleh sistem Netra · Dinas Komunikasi dan Informatika Kabupaten Pringsewu
  </p>
</div>
<script>window.addEventListener('load', () => window.print());</script>
</body>
</html>
