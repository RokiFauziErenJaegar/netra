# ===========================================
# NETRA - Konfigurasi Aplikasi
# Salin file ini menjadi .env lalu sesuaikan.
# ===========================================

# --- HTTP Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=production
TRUST_PROXY=false

# --- Logging ---
# Level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
LOG_PRETTY=true

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=db_monitoring_pringsewu
DB_POOL_LIMIT=10

# --- MikroTik Diskominfo (Router Utama) ---
MIKROTIK_DISKOMINFO_HOST=10.100.100.1
MIKROTIK_DISKOMINFO_USER=latsar
MIKROTIK_DISKOMINFO_PASSWORD=latsar
MIKROTIK_DISKOMINFO_PORT=8728
MIKROTIK_DISKOMINFO_TLS=false
MIKROTIK_DISKOMINFO_TIMEOUT_MS=5000

# --- MikroTik Rumah ---
MIKROTIK_RUMAH_HOST=192.168.1.11
MIKROTIK_RUMAH_USER=admin
MIKROTIK_RUMAH_PASSWORD=
MIKROTIK_RUMAH_PORT=8728
MIKROTIK_RUMAH_TLS=false
MIKROTIK_RUMAH_TIMEOUT_MS=5000

# --- Interval Polling (millidetik) ---
# Polling sub-detik mungkin untuk angka < 1000, tapi pertimbangkan
# beban CPU pada router. Default: 5 detik (5000ms) untuk produksi.
POLL_INTERVAL_DISKOMINFO_MS=5000
POLL_INTERVAL_RUMAH_MS=5000

# --- OPD Router Multi-tenant (untuk halaman List User OPD) ---
# Format: NAMA|HOST|USER|PASSWORD ; (dipisah titik koma)
# Contoh: Inspektorat|172.16.1.10|admin|pass;BKD|172.16.1.46|admin|pass;Kominfo|172.16.1.122|admin|pass
OPD_ROUTERS=Inspektorat|172.16.1.10|admin|admin;BKD|172.16.1.46|admin|admin;Kominfo|172.16.1.122|admin|admin
OPD_ROUTER_TIMEOUT_MS=3000

# --- Fonnte WhatsApp ---
FONNTE_TOKEN=
FONNTE_TARGET=
FONNTE_ENABLED=true

# --- Telegram Bot (opsional) ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# --- Notifikasi ---
# Cooldown notifikasi (millidetik) untuk hindari spam saat flap.
NOTIF_COOLDOWN_MS=300000
